menu "Robusto Proxy"

    config ROBUSTO_PROXY
        bool "Enable Robusto proxy"
        default n

    choice ROBUSTO_PROXY_ROLE
        prompt "Proxy role"
        depends on ROBUSTO_PROXY

        config ROBUSTO_PROXY_CLIENT
            bool "Delegating controller/client"

        config ROBUSTO_PROXY_SERVER
            bool "Delegated instance/server"

    endchoice

    config ROBUSTO_PROXY_SERVICE_PUBSUB
        bool "Enable PubSub delegation"
        depends on ROBUSTO_PROXY
        depends on ROBUSTO_PROXY_CLIENT || ROBUSTO_PUBSUB_SERVER
        default y

    choice ROBUSTO_PROXY_PROFILE
        prompt "Resource profile"
        depends on ROBUSTO_PROXY

        config ROBUSTO_PROXY_PROFILE_LOW_MEMORY
            bool "Low memory"

        config ROBUSTO_PROXY_PROFILE_STANDARD
            bool "Standard (not implemented for ESP SDIO)"
            help
                The portable standard profile is defined and native-tested,
                but the ESP32-P4/ESP32-C6 SDIO runtime currently allocates only
                the low-memory profile capacities. Selecting this profile for
                either ESP SDIO target stops configuration with an error.

    endchoice

    orsource "transports/esp_sdio/Kconfig"

endmenu